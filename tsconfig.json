{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "allowJs": false,
        "checkJs": false,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true
    },
    "include": [
        "client/src/**/*.ts",
        "server/src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "server/dist"
    ]
}